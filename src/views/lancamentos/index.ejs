<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<main class="container-fluid app-main">
  <%- include('../partials/flash') %>

  <div class="page-heading">
    <div>
      <span class="app-kicker">Financeiro manual</span>
      <h1>Lancamentos de entradas e saidas</h1>
    </div>
  </div>

  <section class="content-grid">
    <form action="/lancamentos" method="post" class="panel stack-form">
      <div class="panel-heading">
        <h2>Novo lancamento</h2>
      </div>
      <div>
        <label class="form-label" for="categoria">Categoria</label>
        <input class="form-control" id="categoria" name="categoria" required>
      </div>
      <div>
        <label class="form-label" for="descricao">Descricao</label>
        <textarea class="form-control" id="descricao" name="descricao" rows="4"></textarea>
      </div>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label" for="valor">Valor</label>
          <input class="form-control" id="valor" name="valor" type="number" step="0.01" required>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="data_lancamento">Data</label>
          <input class="form-control" id="data_lancamento" name="data_lancamento" type="datetime-local">
        </div>
      </div>
      <div class="form-check">
        <input class="form-check-input" id="status_pagamento" name="status_pagamento" type="checkbox">
        <label class="form-check-label" for="status_pagamento">Pago</label>
      </div>
      <button class="btn btn-primary align-self-start" type="submit">Registrar</button>
    </form>

    <section class="panel">
      <div class="panel-heading">
        <h2>Extrato manual</h2>
      </div>
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead>
            <tr>
              <th>Categoria</th>
              <th>Descricao</th>
              <th>Valor</th>
              <th>Status</th>
              <th>Data</th>
            </tr>
          </thead>
          <tbody>
            <% lancamentos.forEach((lancamento) => { %>
              <tr>
                <td><%= lancamento.categoria %></td>
                <td><%= lancamento.descricao %></td>
                <td><%= lancamento.valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                <td><span class="status-pill"><%= lancamento.status_pagamento ? 'Pago' : 'Pendente' %></span></td>
                <td><%= new Date(lancamento.data_lancamento).toLocaleString('pt-BR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </section>
</main>

<%- include('../partials/footer') %>
